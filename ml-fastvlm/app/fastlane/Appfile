# See IOS_DEPLOYMENT_RUNBOOK.md Phase 0d for how to fill these in.
# All three values are read from environment variables in CI; the literals
# below are fallbacks for local fastlane invocations on a Mac (rare).

app_identifier(ENV["APP_BUNDLE_IDENTIFIER"] || "com.example.iris")
apple_id(ENV["APPLE_ID"] || "you@example.com")
team_id(ENV["APPLE_TEAM_ID"] || "0000000000")

# itc_team_id is the App Store Connect team id; it equals team_id for
# single-team accounts (which is what the $99/yr Personal plan gives you).
itc_team_id(ENV["APPLE_TEAM_ID"] || "0000000000")
